# --- SYSTEM PORTS ---
PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# --- DATABASE SETUP ---
# PostgreSQL database URL (Used by Prisma ORM)
DATABASE_URL="postgresql://postgres:password123@localhost:5432/venuevoxai_db?schema=public"

# --- SECURITY ---
# Secret key for signing JSON Web Tokens (JWT)
JWT_SECRET="super-secret-jwt-signing-key-change-in-prod"
JWT_EXPIRES_IN="7d"

# --- MOCK DATA SEEDING (Optional) ---
# Toggle whether store loads mock data or starts blank
SEED_MOCK_DATA=true

# --- VOICE AI AGENTS (VAPI & GEMINI) ---
# Vapi API Key for provisioning AI receptionists
VAPI_API_KEY="your-vapi-private-key-here"
NEXT_PUBLIC_VAPI_PUBLIC_KEY="your-vapi-public-key-here"

# Gemini API Key for resolving webhook calendar queries
GEMINI_API_KEY="your-google-gemini-key-here"

# Webhook Callback URL (Must be publicly accessible e.g. ngrok if testing locally)
BACKEND_URL="http://localhost:3001"
